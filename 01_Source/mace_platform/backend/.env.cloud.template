# ─────────────────────────────────────────────────────────────────────
# MACE Secure Files — CLOUD .env template
# Copy this to `.env` on the server and fill the blanks. Keep OFF chat/email.
# Leave a value blank to keep that feature in local/offline mode.
# ─────────────────────────────────────────────────────────────────────

# ── Core (required) ──────────────────────────────────────────────────
ENVIRONMENT=production
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# ── AWS: encryption + storage (the cloud-security core) ──────────────
S3_REGION=us-east-1
S3_BUCKET=                         # e.g. mace-secure-files-yourco
AWS_ACCESS_KEY_ID=                 # from the mace-app IAM user
AWS_SECRET_ACCESS_KEY=             # from the mace-app IAM user

# Turn on KMS envelope encryption (set true once the key exists):
MACE_KMS_ENABLED=false
MACE_KMS_KEY_ID=                   # arn:aws:kms:us-east-1:ACCT:key/....  or alias/mace-files

# Redact secrets/PII by default on upload:
MACE_REDACT_BY_DEFAULT=false

# ── AI safeguard (optional LLM pass) ─────────────────────────────────
ANTHROPIC_API_KEY=                 # sk-ant-...  (leave blank for offline rules-only)
MACE_AI_GUARD_MODEL=claude-sonnet-4-6

# ── Elasticsearch / Kibana audit search (optional) ───────────────────
ELASTIC_ENABLED=false
ELASTIC_URL=http://elasticsearch:9200
ELASTIC_AUDIT_INDEX=mace-secure-file-audit

# ── Database / cache (Compose provides these by default) ─────────────
DATABASE_URL=postgresql+asyncpg://mace:mace@postgres:5432/mace_platform
REDIS_URL=redis://redis:6379/0

# ── Optional integrations ────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# SMTP_PASSWORD=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
