# ── App ──────────────────────────────────────────────────────────────
APP_NAME=UnifiedSec MACE Platform
APP_VERSION=2.0.0
DEBUG=false
ENVIRONMENT=production    # development | staging | production
DEPLOYMENT_REGION=us-east-1
DATA_RESIDENCY_JURISDICTION=US

# ── Security ─────────────────────────────────────────────────────────
# REQUIRED in production — at least 32 chars, recommend 64+.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ─────────────────────────────────────────────────────────
# MUST use the asyncpg driver.
# Local docker-compose default: mace / mace_dev_password_change_in_prod / mace_platform
DATABASE_URL=postgresql+asyncpg://mace:mace_dev_password_change_in_prod@localhost:5432/mace_platform

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://:mace_redis_dev@localhost:6379/0
CELERY_BROKER_URL=redis://:mace_redis_dev@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:mace_redis_dev@localhost:6379/2

# ── MACE algorithm path ──────────────────────────────────────────────
# Local dev only — Docker sets this to /app via the image.
# Leave unset if running with PYTHONPATH already pointing at UnifiedSec_MACE_v2.
# MACE_CORE_PATH=/path/to/UnifiedSec_MACE_v2

# ── OAuth2 / SSO (optional) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Stripe (optional — billing disabled if blank) ────────────────────
# Use sk_test_... keys during development.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PROFESSIONAL=
STRIPE_PRICE_ID_ENTERPRISE=

# ── Email (optional — auth emails disabled if blank) ─────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
EMAILS_FROM=noreply@unifiedsec.com

# ── S3 evidence storage (optional in dev) ────────────────────────────
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── MACE Engine ──────────────────────────────────────────────────────
MACE_DEFAULT_WEIGHT_PROFILE=usa_fedramp
MACE_CDCS_ALERT_THRESHOLD=7.0
MACE_REA_CDCS_THRESHOLD=6.5
MACE_MATCH_THRESHOLD=0.38
